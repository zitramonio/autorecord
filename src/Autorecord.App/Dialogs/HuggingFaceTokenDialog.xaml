<Window x:Class="Autorecord.App.Dialogs.HuggingFaceTokenDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Скачать модель для разделения на спикеров"
        Width="820"
        Height="900"
        MinWidth="720"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="#D7DCE3"
                BorderThickness="1"
                CornerRadius="8"
                Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="18">
                <StackPanel>
                    <TextBlock Text="Установка модели Pyannote Community-1 через Hugging Face"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,18" />

                    <TextBlock Text="Шаг 1. Войдите/зарегистрируйтесь в Hugging Face"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />
                    <TextBlock Text="Откройте страницу входа:"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4" />
                    <TextBlock TextWrapping="Wrap"
                               Margin="0,0,0,12">
                        <Hyperlink NavigateUri="https://huggingface.co/login"
                                   RequestNavigate="OpenLink_RequestNavigate">https://huggingface.co/login</Hyperlink>
                    </TextBlock>
                    <TextBlock Text="Если аккаунт уже есть, войдите. Если нет, зарегистрируйтесь, введя логин и пароль, а в следующем окне свои данные:"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />
                    <Image Source="pack://application:,,,/Assets/HuggingFace/hf1.png"
                           Stretch="Uniform"
                           MaxHeight="420"
                           Margin="0,0,0,12" />
                    <Image Source="pack://application:,,,/Assets/HuggingFace/hf2.png"
                           Stretch="Uniform"
                           MaxHeight="420"
                           Margin="0,0,0,18" />
                    <TextBlock Text="Подтвердите адрес электронной почты и создайте организацию:"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />
                    <Image Source="pack://application:,,,/Assets/HuggingFace/hf3.png"
                           Stretch="Uniform"
                           MaxHeight="420"
                           Margin="0,0,0,12" />
                    <Image Source="pack://application:,,,/Assets/HuggingFace/hf4.png"
                           Stretch="Uniform"
                           MaxHeight="420"
                           Margin="0,0,0,22" />

                    <TextBlock Text="Шаг 2. Примите условия доступа к модели"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />
                    <TextBlock Text="Откройте страницу модели:"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4" />
                    <TextBlock TextWrapping="Wrap"
                               Margin="0,0,0,12">
                        <Hyperlink NavigateUri="https://huggingface.co/pyannote/speaker-diarization-community-1"
                                   RequestNavigate="OpenLink_RequestNavigate">https://huggingface.co/pyannote/speaker-diarization-community-1</Hyperlink>
                    </TextBlock>
                    <TextBlock Text="На странице модели заполните данные вашей компании, Use case и нажмите кнопку согласия с условиями доступа:"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />
                    <Image Source="pack://application:,,,/Assets/HuggingFace/hf5.png"
                           Stretch="Uniform"
                           MaxHeight="420"
                           Margin="0,0,0,22" />

                    <TextBlock Text="Шаг 3. Создайте Read-token"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />
                    <TextBlock Text="Откройте страницу access tokens:"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4" />
                    <TextBlock TextWrapping="Wrap"
                               Margin="0,0,0,12">
                        <Hyperlink NavigateUri="https://huggingface.co/settings/tokens"
                                   RequestNavigate="OpenLink_RequestNavigate">https://huggingface.co/settings/tokens</Hyperlink>
                    </TextBlock>
                    <TextBlock Text="Выберите создание нового token с правами Read:"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />
                    <Image Source="pack://application:,,,/Assets/HuggingFace/hf6.png"
                           Stretch="Uniform"
                           MaxHeight="420"
                           Margin="0,0,0,12" />
                    <Image Source="pack://application:,,,/Assets/HuggingFace/hf7.png"
                           Stretch="Uniform"
                           MaxHeight="420"
                           Margin="0,0,0,18" />
                    <TextBlock Text="После создания Hugging Face показывает token один раз. Скопируйте его сразу:"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />
                    <Image Source="pack://application:,,,/Assets/HuggingFace/hf8.png"
                           Stretch="Uniform"
                           MaxHeight="420"
                           Margin="0,0,0,22" />

                    <TextBlock Text="Шаг 4. Вставьте token в приложение"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />
                    <TextBlock Text="Вставьте token в поле внизу окна и нажмите `Скачать`."
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />
                    <TextBlock Text="Token используется только для скачивания этой модели и не сохраняется приложением."
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="1"
                BorderBrush="#D7DCE3"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,12,0,0"
                Background="White">
            <StackPanel>
                <TextBlock Text="Hugging Face access token"
                           Margin="0,0,0,4" />
                <PasswordBox x:Name="TokenBox"
                             Height="30"
                             Margin="0,0,0,8" />
                <TextBlock Text="Токен используется только для скачивания этой модели и не сохраняется приложением."
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Width="96"
                            Height="30"
                            Margin="0,0,8,0"
                            IsDefault="True"
                            Click="Ok_Click">
                        Скачать
                    </Button>
                    <Button Width="96"
                            Height="30"
                            IsCancel="True">
                        Отмена
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
